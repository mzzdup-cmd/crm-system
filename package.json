{
  "name": "crm-school-v2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "functions:install": "npm install --prefix functions",
    "functions:deploy": "firebase deploy --only functions",
    "firestore:deploy": "firebase deploy --only firestore",
    "deploy:hosting": "npm run build && firebase deploy --only hosting",
    "deploy:production": "npm run build && firebase deploy --only hosting,functions,firestore",
    "test:rules": "firebase emulators:exec --only firestore \"node --test tests/firestore/*.test.js\"",
    "test:rules:run": "node --test tests/firestore/*.test.js"
  },
  "dependencies": {
    "firebase": "^12.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-is": "^19.2.6",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.12"
  },
  "overrides": {
    "react-is": "^19.2.6"
  }
}
