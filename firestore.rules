rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(
        /databases/$(database)/documents/users/$(request.auth.uid)
      ).data;
    }

    function hasUserProfile() {
      return isSignedIn()
        && exists(
          /databases/$(database)/documents/users/$(request.auth.uid)
        );
    }

    function isAdmin() {
      return hasUserProfile()
        && userDoc().keys().hasAny(['role'])
        && userDoc().role == 'admin';
    }

    function isRop() {
      return hasUserProfile()
        && userDoc().keys().hasAny(['role'])
        && userDoc().role == 'rop';
    }

    function isLeadership() {
      return isAdmin() || isRop();
    }

    function isManager() {
      return hasUserProfile()
        && userDoc().keys().hasAny(['role'])
        && userDoc().role == 'manager';
    }

    function isOperationalUser() {
      return hasUserProfile()
        && !isLeadership();
    }

    function ownerManagerId() {
      return userDoc().managerId;
    }

    function ownerManagerName() {
      return userDoc().name;
    }

    function canonicalManagerId(managerId) {
      return managerId == 'polina_plamadyala'
        ? 'polina_plamadya'
        : managerId == 'vilu_petrova'
          ? 'violeta_petrova'
          : managerId == 'denis'
            ? 'denis_manuilov'
            : managerId == 'ruslan'
              ? 'ruslan_romanyuk'
              : managerId == 'alexander'
                ? 'alexander_simanov'
                : managerId == 'sergey'
                  ? 'sergey_grebenshchikov'
                  : managerId == 'andrey'
                    ? 'andrey_volkov'
                    : managerId == 'katya'
                      ? 'katya_bakaeva'
                      : managerId == 'vilu'
                        ? 'violeta_petrova'
                        : managerId == 'violeta'
                          ? 'violeta_petrova'
                          : managerId == 'Денис М'
                            ? 'denis_manuilov'
                            : managerId;
    }

    function managerIdFromOwnerName() {
      return resolveManagerIdFromDisplayName(
        ownerManagerName()
      );
    }

    function authEmailLocalPart() {
      return request.auth.token.email != null
        ? request.auth.token.email.lower().split('@')[0]
        : '';
    }

    function managerIdFromAuthEmail() {
      return authEmailLocalPart() == 'katya'
        || authEmailLocalPart() == 'katya_bakaeva'
        ? 'katya_bakaeva'
        : authEmailLocalPart() == 'denis'
          || authEmailLocalPart() == 'denis_manuilov'
          ? 'denis_manuilov'
          : authEmailLocalPart() == 'ruslan'
            || authEmailLocalPart() == 'ruslan_romanyuk'
            ? 'ruslan_romanyuk'
            : authEmailLocalPart() == 'alexander'
              || authEmailLocalPart() == 'alexander_simanov'
              ? 'alexander_simanov'
              : authEmailLocalPart() == 'sergey'
                || authEmailLocalPart()
                  == 'sergey_grebenshchikov'
                ? 'sergey_grebenshchikov'
                : authEmailLocalPart() == 'andrey'
                  || authEmailLocalPart() == 'andrey_volkov'
                  ? 'andrey_volkov'
                  : authEmailLocalPart() == 'polina.p'
                    || authEmailLocalPart() == 'polina_penkova'
                    ? 'polina_penkova'
                    : authEmailLocalPart() == 'polina.pl'
                      || authEmailLocalPart()
                        == 'polina_plamadya'
                      ? 'polina_plamadya'
                      : authEmailLocalPart() == 'vilu'
                        || authEmailLocalPart() == 'vilu_petrova'
                        || authEmailLocalPart() == 'violeta'
                        || authEmailLocalPart()
                          == 'violeta_petrova'
                        ? 'violeta_petrova'
                        : null;
    }

    function ownerManagerIdFromProfile() {
      let rawManagerId =
        ownerManagerId();

      return rawManagerId != null
        && rawManagerId != ''
        ? canonicalManagerId(
            rawManagerId
          )
        : null;
    }

    function ownerManagerIdFromNameOrProfile() {
      let fromOwnerName =
        managerIdFromOwnerName();

      return fromOwnerName != null
        ? fromOwnerName
        : ownerManagerIdFromProfile();
    }

    function effectiveOwnerManagerId() {
      let fromAuth =
        managerIdFromAuthEmail();

      return fromAuth != null
        ? fromAuth
        : ownerManagerIdFromNameOrProfile();
    }

    function isOwnAuditCreate() {
      return request.resource.data.createdByUid
        == request.auth.uid;
    }

    function hasManagerAttribution(data) {
      return data.managerId is string
        && data.manager is string
        && data.managerId != ''
        && data.manager != '';
    }

    function canCreateManagerData(data) {
      return isLeadership()
        || (
          isSignedIn()
          && hasUserProfile()
          && isOwnAuditCreate()
          && hasManagerAttribution(data)
          && ownsManagerRecord(data)
        );
    }

    function canUpdateManagerData(
      existing,
      incoming
    ) {
      return isLeadership()
        || (
          isSignedIn()
          && existing.createdByUid
            == request.auth.uid
        )
        || (
          ownsManagerRecord(existing)
          && optionalFieldEquals(
            incoming.managerId,
            existing.managerId
          )
          && optionalFieldEquals(
            incoming.manager,
            existing.manager
          )
        )
        || (
          existing.managerId == null
          && isLegacyOwner(existing.manager)
          && incoming.manager == existing.manager
        );
    }

    function clientManagerFieldsUnchanged() {
      return optionalFieldEquals(
        request.resource.data.managerId,
        resource.data.managerId
      )
        && optionalFieldEquals(
          request.resource.data.manager,
          resource.data.manager
        );
    }

    function managerCanUpdateOwnedClient() {
      return isOperationalUser()
        && isActiveRecord(resource.data)
        && ownsManagerRecord(resource.data)
        && clientManagerFieldsUnchanged();
    }

    function managerCanPatchClientContactFields() {
      return isOperationalUser()
        && isActiveRecord(resource.data)
        && ownsManagerRecord(resource.data)
        && clientManagerFieldsUnchanged()
        && request.resource.data
          .diff(resource.data)
          .affectedKeys()
          .hasOnly([
            'vkLink',
            'dialogLink',
            'clientNote',
            'updatedAt',
          ]);
    }

    function managerIdsMatch(leftId, rightId) {
      return leftId != null
        && rightId != null
        && canonicalManagerId(leftId)
          == canonicalManagerId(rightId);
    }

    function isOwnerByManagerId(managerId) {
      return managerIdsMatch(
        effectiveOwnerManagerId(),
        managerId
      );
    }

    function isLegacyOwner(managerName) {
      return managerName != null
        && ownerManagerName() != null
        && ownerManagerName() == managerName;
    }

    function resolveManagerIdFromDisplayName(name) {
      return name == 'Катя'
        || name == 'Катя Бакаева'
        ? 'katya_bakaeva'
        : name == 'Руслан'
          || name == 'Руслан Романюк'
          || name == 'Руслан Р'
          ? 'ruslan_romanyuk'
          : name == 'Полина'
            || name == 'Полина Пенькова'
            ? 'polina_penkova'
            : name == 'Полина Пламадяла'
              ? 'polina_plamadya'
              : name == 'Сергей Гребенщиков'
                || name == 'Сергей Г'
                ? 'sergey_grebenshchikov'
                : name == 'Денис Мануйлов'
                  || name == 'Денис М'
                  ? 'denis_manuilov'
                  : name == 'Андрей Волков'
                    || name == 'Андрей В'
                    ? 'andrey_volkov'
                    : name == 'Александр Симанов'
                      || name == 'Александр С'
                      ? 'alexander_simanov'
                      : name == 'Виолетта Петрова'
                        || name == 'Виолетта П'
                        ? 'violeta_petrova'
                        : null;
    }

    function resolveManagerKey(value) {
      let fromName =
        resolveManagerIdFromDisplayName(value);

      return value == null
        || value == ''
        ? null
        : fromName != null
          ? fromName
          : canonicalManagerId(value);
    }

    function resolvedDataManagerId(data) {
      return data.managerId != null
        && data.managerId != ''
        ? canonicalManagerId(
            data.managerId
          )
        : (
          data.manager != null
          && data.manager != ''
            ? resolveManagerKey(
                data.manager
              )
            : null
        );
    }

    function ownsManagerRecord(data) {
      let ownerId =
        effectiveOwnerManagerId();
      let dataId =
        resolvedDataManagerId(data);
      let ownerName =
        ownerManagerName();

      return isLeadership()
        || (
          ownerId != null
          && dataId != null
          && dataId == ownerId
        )
        || (
          ownerName != null
          && data.manager != null
          && data.manager != ''
          && data.manager == ownerName
        );
    }

    function canReadManagerData(data) {
      return isLeadership()
        || ownsManagerRecord(data)
        || (
          data.managerId == null
          && isLegacyOwner(data.manager)
        );
    }

    function isSelfUserBootstrapCreate() {
      return isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.email
          == request.auth.token.email
        && request.resource.data.role
          in ['manager', 'admin', 'rop']
        && request.resource.data.name is string
        && request.resource.data.updatedAt is int;
    }

    function isSelfUserProfileTouch() {
      return isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.role
          == resource.data.role
        && request.resource.data.email
          == resource.data.email;
    }

    match /users/{uid} {
      allow read: if isSignedIn()
        && (
          request.auth.uid == uid
          || isLeadership()
          || resource.data.role in ['manager', 'admin', 'rop']
        );

      allow create: if isAdmin()
        || isSelfUserBootstrapCreate();

      allow update: if isAdmin()
        || isSelfUserProfileTouch();

      allow delete: if isAdmin();
    }

    match /clients/{clientId} {
      allow read: if isSignedIn()
        && canReadManagerData(resource.data);

      allow create: if isSignedIn()
        && canCreateManagerData(request.resource.data);

      allow update: if isSignedIn()
        && (
          canUpdateManagerData(
            resource.data,
            request.resource.data
          )
          || managerCanUpdateOwnedClient()
          || managerCanPatchClientContactFields()
        );

      allow delete: if isAdmin();
    }

    function isRecentPayment() {
      return resource.data.createdAt is int
        && resource.data.createdAt
          > request.time.toMillis() - 30 * 60 * 1000;
    }

    function managerCanEditPayment() {
      return isOperationalUser()
        && ownsManagerRecord(resource.data)
        && isRecentPayment()
        && resource.data.deletedAt == null
        && managerIdsMatch(
          request.resource.data.managerId,
          resource.data.managerId
        )
        && request.resource.data.clientId
          == resource.data.clientId
        && request.resource.data.deletedAt == null;
    }

    function clientOwnershipForPayment(data) {
      return data.clientId != null
        && data.clientId != ''
        && exists(
          /databases/$(database)/documents/clients/$(data.clientId)
        )
        && ownsManagerRecord(
          get(
            /databases/$(database)/documents/clients/$(data.clientId)
          ).data
        );
    }

    function canAccessPaymentInRules(data) {
      return isLeadership()
        || (
          isOperationalUser()
          && (
            ownsManagerRecord(data)
            || clientOwnershipForPayment(data)
          )
        );
    }

    function isStartDatePatchUpdate() {
      return request.resource.data
        .diff(resource.data)
        .affectedKeys()
        .hasOnly([
          'startDate',
          'updatedAt',
          'updatedByUid',
          'managerId',
          'manager',
          'ttStartDateResyncPending',
        ]);
    }

    function isVkResyncQueuePatchUpdate() {
      return request.resource.data
        .diff(resource.data)
        .affectedKeys()
        .hasOnly([
          'ttVkResyncPending',
          'updatedAt',
          'updatedByUid',
          'managerId',
          'manager',
        ]);
    }

    function isCuratorStartDatePatchUpdate() {
      return request.resource.data
        .diff(resource.data)
        .affectedKeys()
        .hasOnly([
          'curatorStartDate',
          'updatedAt',
          'updatedByUid',
          'managerId',
          'manager',
        ]);
    }

    function resolveDealTypeId(value) {
      return value == 'ББ'
        || value == 'bb'
        || value == 'BB'
        || (
          value is string
          && value.lower() == 'бб'
        )
        ? 'bb'
        : value == 'Рассылка'
          || value == 'mailing'
          || (
            value is string
            && value.lower() == 'рассылка'
          )
          ? 'mailing'
          : value;
    }

    function isOptionalStartDateDealType(
      dealType
    ) {
      return resolveDealTypeId(dealType) == 'bb'
        || resolveDealTypeId(dealType)
          == 'mailing';
    }

    function ownsPaymentRecord(data) {
      return ownsManagerRecord(data)
        || (
          data.clientId != null
          && data.clientId != ''
          && exists(
            /databases/$(database)/documents/clients/$(data.clientId)
          )
          && ownsManagerRecord(
            get(
              /databases/$(database)/documents/clients/$(data.clientId)
            ).data
          )
        );
    }

    function isStaffMember() {
      return hasUserProfile()
        && !isLeadership()
        && effectiveOwnerManagerId() != null;
    }

    function optionalFieldEquals(
      left,
      right
    ) {
      return left == right
        || (
          (left == null || left == '')
          && (right == null || right == '')
        );
    }

    function paymentManagerIdUnchanged() {
      return managerIdsMatch(
        request.resource.data.managerId,
        resource.data.managerId
      )
        || optionalFieldEquals(
          request.resource.data.managerId,
          resource.data.managerId
        );
    }

    function paymentCoreFieldsUnchanged() {
      return request.resource.data.dealType
          == resource.data.dealType
        && paymentManagerIdUnchanged()
        && optionalFieldEquals(
          request.resource.data.clientId,
          resource.data.clientId
        )
        && request.resource.data.amount
          == resource.data.amount
        && optionalFieldEquals(
          request.resource.data.paymentDate,
          resource.data.paymentDate
        )
        && optionalFieldEquals(
          request.resource.data.paymentSystem,
          resource.data.paymentSystem
        )
        && optionalFieldEquals(
          request.resource.data.invoiceNumber,
          resource.data.invoiceNumber
        );
    }

    function isActiveRecord(data) {
      return !(data.deletedAt is int)
        && !(data.deletedAt is timestamp);
    }

    function paymentHasOptionalStartDate(
      data
    ) {
      return isOptionalStartDateDealType(
        data.dealType
      )
        || (
          data.keys().hasAny(['dealTypeId'])
          && isOptionalStartDateDealType(
            data.dealTypeId
          )
        );
    }

    function paymentPatchOwnershipOk() {
      return ownsPaymentRecord(resource.data)
        && paymentManagerIdUnchanged()
        && resource.data.deletedAt == null
        && request.resource.data.deletedAt == null;
    }

    // Cheap path: no get() calls — avoids rule evaluation limits.
    function canPatchOptionalStartDate() {
      return isSignedIn()
        && isStartDatePatchUpdate()
        && paymentHasOptionalStartDate(
          resource.data
        )
        && paymentPatchOwnershipOk();
    }

    function canPatchVkResyncQueue() {
      return isSignedIn()
        && isVkResyncQueuePatchUpdate()
        && resource.data.syncedToSheets == true
        && paymentPatchOwnershipOk();
    }

    function canPatchCuratorStartDate() {
      return isSignedIn()
        && isCuratorStartDatePatchUpdate()
        && paymentPatchOwnershipOk();
    }

    match /payments/{paymentId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && canCreateManagerData(request.resource.data);

      allow update: if isSignedIn()
        && (
          canPatchOptionalStartDate()
          || canPatchVkResyncQueue()
          || canPatchCuratorStartDate()
          || isLeadership()
          || managerCanEditPayment()
        );

      allow delete: if false;
    }

    match /manualBonuses/{bonusId} {
      allow read: if isSignedIn()
        && canReadManagerData(resource.data);

      allow create, update, delete: if isLeadership();
    }

    match /nightShifts/{shiftId} {
      allow read: if isSignedIn()
        && canReadManagerData(resource.data);

      allow create, update, delete: if isLeadership();
    }

    match /schedule/{dateId} {
      allow read: if isSignedIn();

      allow create, update, delete: if isLeadership();
    }

    match /syncLog/{logId} {
      allow read: if isLeadership();

      allow write: if false;
    }

    match /traffic/{docId} {
      allow read: if isSignedIn();

      allow create, update, delete: if isLeadership();
    }

    match /trafficSources/{sourceId} {
      allow read: if isSignedIn();

      allow create, update, delete: if isLeadership();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn()
        && (
          isLeadership()
          || request.resource.data.userId == request.auth.uid
          || (
            request.resource.data.type == 'pending_sale'
            && request.resource.data.userId is string
            && request.resource.data.dedupKey is string
          )
        );

      allow update: if isSignedIn()
        && (
          (
            resource.data.userId == request.auth.uid
            && request.resource.data.userId == resource.data.userId
          )
          || isLeadership()
        );

      allow delete: if isLeadership();
    }

    function isPendingOwner(data) {
      return isLeadership()
        || isOwnerByManagerId(data.ownerManagerId);
    }

    function isPendingCreator(data) {
      return isLeadership()
        || isOwnerByManagerId(data.createdByManagerId);
    }

    match /pendingSales/{saleId} {
      allow read: if isSignedIn()
        && (
          isPendingOwner(resource.data)
          || isPendingCreator(resource.data)
        );

      allow create: if isSignedIn()
        && (
          isLeadership()
          || (
            isStaffMember()
            && request.resource.data.createdByManagerId
              != null
            && managerIdsMatch(
              request.resource.data.createdByManagerId,
              effectiveOwnerManagerId()
            )
            && request.resource.data.ownerManagerId
              != request.resource.data.createdByManagerId
            && request.resource.data.status == 'pending'
          )
        );

      allow update: if isSignedIn()
        && (
          isLeadership()
          || (
            isPendingOwner(resource.data)
            && resource.data.status == 'pending'
            && request.resource.data.ownerManagerId == resource.data.ownerManagerId
            && request.resource.data.createdByManagerId == resource.data.createdByManagerId
          )
        );

      allow delete: if isLeadership();
    }

    function canCreateOwnManagerRequest() {
      return isSignedIn()
        && hasUserProfile()
        && request.resource.data.status == 'pending'
        && hasManagerAttribution(
          request.resource.data
        )
        && (
          isLeadership()
          || ownsManagerRecord(
            request.resource.data
          )
        );
    }

    function isOwnTimeOffRequest(data) {
      return canReadManagerData(data)
        || ownsManagerRecord(data);
    }

    match /timeOffRequests/{requestId} {
      allow read: if isSignedIn()
        && (
          isLeadership()
          || isOwnTimeOffRequest(resource.data)
        );

      allow create: if canCreateOwnManagerRequest();

      allow update: if isLeadership();

      allow delete: if false;
    }

    match /vacationRequests/{requestId} {
      allow read: if isSignedIn()
        && (
          isLeadership()
          || isOwnTimeOffRequest(resource.data)
        );

      allow create: if canCreateOwnManagerRequest();

      allow update: if isLeadership();

      allow delete: if false;
    }

    match /calendarEvents/{eventId} {
      allow read: if isSignedIn();

      allow create, update, delete: if isLeadership();
    }

    match /knowledgeFaq/{itemId} {
      allow read: if isSignedIn();

      allow create, update, delete: if isLeadership();
    }

    match /knowledgeNotes/{itemId} {
      allow read: if isSignedIn();

      allow create, update, delete: if isLeadership();
    }

    function canCreateOwnKnowledgeScript() {
      return isSignedIn()
        && hasUserProfile()
        && hasManagerAttribution(
          request.resource.data
        )
        && (
          isLeadership()
          || ownsManagerRecord(
            request.resource.data
          )
        );
    }

    function canUpdateOwnKnowledgeScript() {
      return isSignedIn()
        && (
          isLeadership()
          || (
            hasUserProfile()
            && ownsManagerRecord(
              resource.data
            )
            && managerIdsMatch(
              request.resource.data.managerId,
              resource.data.managerId
            )
          )
        );
    }

    match /knowledgeScripts/{itemId} {
      allow read: if isSignedIn();

      allow create: if canCreateOwnKnowledgeScript();

      allow update: if canUpdateOwnKnowledgeScript();

      allow delete: if isLeadership();
    }
  }
}
