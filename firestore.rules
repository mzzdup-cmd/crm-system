rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(
        /databases/$(database)/documents/users/$(request.auth.uid)
      ).data;
    }

    function isRop() {
      return isSignedIn()
        && userDoc().role == 'rop';
    }

    function isLeadership() {
      return isAdmin() || isRop();
    }

    function isAdmin() {
      return isSignedIn()
        && userDoc().role == 'admin';
    }

    function isManager() {
      return isSignedIn()
        && userDoc().role == 'manager';
    }

    function ownerManagerId() {
      return userDoc().managerId;
    }

    function ownerManagerName() {
      return userDoc().name;
    }

    function isOwnerByManagerId(managerId) {
      return isManager()
        && managerId != null
        && ownerManagerId() == managerId;
    }

    function isLegacyOwner(managerName) {
      return isManager()
        && managerName != null
        && ownerManagerName() == managerName;
    }

    function canReadManagerData(data) {
      return isLeadership()
        || isOwnerByManagerId(data.managerId)
        || (
          data.managerId == null
          && isLegacyOwner(data.manager)
        );
    }

    function canCreateManagerData(data) {
      return isLeadership()
        || (
          isOwnerByManagerId(data.managerId)
          && data.managerId != null
        );
    }

    function canUpdateManagerData(
      existing,
      incoming
    ) {
      return isLeadership()
        || (
          isOwnerByManagerId(existing.managerId)
          && incoming.managerId == existing.managerId
        )
        || (
          existing.managerId == null
          && isLegacyOwner(existing.manager)
          && incoming.manager == existing.manager
        );
    }

    match /users/{uid} {
      allow read: if isSignedIn()
        && (
          request.auth.uid == uid
          || isLeadership()
          || resource.data.role in ['manager', 'admin', 'rop']
        );

      allow create, update, delete: if isAdmin();
    }

    match /clients/{clientId} {
      allow read: if isSignedIn()
        && canReadManagerData(resource.data);

      allow create: if isSignedIn()
        && canCreateManagerData(request.resource.data);

      allow update: if isSignedIn()
        && canUpdateManagerData(
          resource.data,
          request.resource.data
        );

      allow delete: if isAdmin();
    }

    function isRecentPayment() {
      return resource.data.createdAt is int
        && resource.data.createdAt
          > request.time.toMillis() - 30 * 60 * 1000;
    }

    function managerCanEditPayment() {
      return isManager()
        && isOwnerByManagerId(resource.data.managerId)
        && isRecentPayment()
        && resource.data.deletedAt == null
        && request.resource.data.managerId
          == resource.data.managerId
        && request.resource.data.clientId
          == resource.data.clientId
        && request.resource.data.deletedAt == null;
    }

    match /payments/{paymentId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && canCreateManagerData(request.resource.data);

      allow update: if isSignedIn()
        && (
          isLeadership()
          || managerCanEditPayment()
        );

      allow delete: if false;
    }

    match /manualBonuses/{bonusId} {
      allow read: if isSignedIn()
        && canReadManagerData(resource.data);

      allow create, update, delete: if isLeadership();
    }

    match /nightShifts/{shiftId} {
      allow read: if isSignedIn()
        && canReadManagerData(resource.data);

      allow create, update, delete: if isLeadership();
    }

    match /schedule/{dateId} {
      allow read: if isSignedIn();

      allow create, update, delete: if isLeadership();
    }

    match /syncLog/{logId} {
      allow read: if isAdmin();

      allow write: if false;
    }

    match /traffic/{docId} {
      allow read: if isSignedIn();

      allow create, update, delete: if isLeadership();
    }

    match /trafficSources/{sourceId} {
      allow read: if isSignedIn();

      allow create, update, delete: if isLeadership();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn()
        && (
          isLeadership()
          || request.resource.data.userId == request.auth.uid
          || (
            request.resource.data.type == 'pending_sale'
            && request.resource.data.userId is string
            && request.resource.data.dedupKey is string
          )
        );

      allow update: if isSignedIn()
        && (
          (
            resource.data.userId == request.auth.uid
            && request.resource.data.userId == resource.data.userId
          )
          || isLeadership()
        );

      allow delete: if isLeadership();
    }

    function isPendingOwner(data) {
      return isLeadership()
        || isOwnerByManagerId(data.ownerManagerId);
    }

    function isPendingCreator(data) {
      return isLeadership()
        || isOwnerByManagerId(data.createdByManagerId);
    }

    match /pendingSales/{saleId} {
      allow read: if isSignedIn()
        && (
          isPendingOwner(resource.data)
          || isPendingCreator(resource.data)
        );

      allow create: if isSignedIn()
        && (
          isLeadership()
          || (
            request.resource.data.createdByManagerId == ownerManagerId()
            && request.resource.data.ownerManagerId != ownerManagerId()
            && request.resource.data.status == 'pending'
          )
        );

      allow update: if isSignedIn()
        && (
          isLeadership()
          || (
            isPendingOwner(resource.data)
            && resource.data.status == 'pending'
            && request.resource.data.ownerManagerId == resource.data.ownerManagerId
            && request.resource.data.createdByManagerId == resource.data.createdByManagerId
          )
        );

      allow delete: if isLeadership();
    }

    function isOwnTimeOffRequest(data) {
      return canReadManagerData(data)
        || (
          isManager()
          && data.manager != null
          && ownerManagerName() == data.manager
        );
    }

    match /timeOffRequests/{requestId} {
      allow read: if isSignedIn()
        && (
          isLeadership()
          || isOwnTimeOffRequest(resource.data)
        );

      allow create: if isSignedIn()
        && isManager()
        && request.resource.data.managerId == ownerManagerId()
        && request.resource.data.status == 'pending';

      allow update: if isLeadership();

      allow delete: if false;
    }

    match /vacationRequests/{requestId} {
      allow read: if isSignedIn()
        && (
          isLeadership()
          || isOwnTimeOffRequest(resource.data)
        );

      allow create: if isSignedIn()
        && isManager()
        && request.resource.data.managerId == ownerManagerId()
        && request.resource.data.status == 'pending';

      allow update: if isLeadership();

      allow delete: if false;
    }

    match /calendarEvents/{eventId} {
      allow read: if isSignedIn();

      allow create, update, delete: if isLeadership();
    }

    match /knowledgeFaq/{itemId} {
      allow read: if isSignedIn();

      allow create, update, delete: if isLeadership();
    }

    match /knowledgeNotes/{itemId} {
      allow read: if isSignedIn();

      allow create, update, delete: if isLeadership();
    }

    function isOwnKnowledgeScript(data) {
      return isLeadership()
        || isOwnerByManagerId(data.managerId);
    }

    match /knowledgeScripts/{itemId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && (
          isLeadership()
          || (
            isManager()
            && request.resource.data.managerId == ownerManagerId()
          )
        );

      allow update: if isSignedIn()
        && (
          isLeadership()
          || (
            isManager()
            && resource.data.managerId == ownerManagerId()
            && request.resource.data.managerId == resource.data.managerId
          )
        );

      allow delete: if isLeadership();
    }
  }
}
